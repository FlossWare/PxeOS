<?xml version="1.0" encoding="utf-8"?>
<!--
  Windows Answer File (unattend.xml)
  Profile: {{ hostname }}
  Generated by PxeOS
-->
<unattend xmlns="urn:schemas-microsoft-com:unattend"
          xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">

  <!-- ======================== -->
  <!-- Pass 1: windowsPE        -->
  <!-- ======================== -->
  <settings pass="windowsPE">

    <component name="Microsoft-Windows-International-Core-WinPE"
               processorArchitecture="{{ profile.arch | default('amd64') }}"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">
      <SetupUILanguage>
        <UILanguage>{{ locale }}</UILanguage>
      </SetupUILanguage>
      <InputLocale>{{ input_locale }}</InputLocale>
      <SystemLocale>{{ locale }}</SystemLocale>
      <UILanguage>{{ locale }}</UILanguage>
      <UserLocale>{{ locale }}</UserLocale>
    </component>

    <component name="Microsoft-Windows-Setup"
               processorArchitecture="{{ profile.arch | default('amd64') }}"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">
      {% if product_key %}
      <UserData>
        <AcceptEula>true</AcceptEula>
        <ProductKey>
          <Key>{{ product_key }}</Key>
        </ProductKey>
        {% if organization %}
        <Organization>{{ organization }}</Organization>
        {% endif %}
        <FullName>{{ owner }}</FullName>
      </UserData>
      {% else %}
      <UserData>
        <AcceptEula>true</AcceptEula>
        {% if organization %}
        <Organization>{{ organization }}</Organization>
        {% endif %}
        <FullName>{{ owner }}</FullName>
      </UserData>
      {% endif %}

      <!-- Disk Configuration -->
      <DiskConfiguration>
        <WillShowUI>OnError</WillShowUI>
        <Disk wcm:action="add">
          <DiskID>{{ disk_id }}</DiskID>
          <WillWipeDisk>true</WillWipeDisk>
          {% if is_uefi %}
          <!-- GPT layout for UEFI -->
          <CreatePartitions>
            <!-- EFI System Partition -->
            <CreatePartition wcm:action="add">
              <Order>1</Order>
              <Size>260</Size>
              <Type>EFI</Type>
            </CreatePartition>
            <!-- Microsoft Reserved -->
            <CreatePartition wcm:action="add">
              <Order>2</Order>
              <Size>128</Size>
              <Type>MSR</Type>
            </CreatePartition>
            <!-- Windows OS -->
            <CreatePartition wcm:action="add">
              <Order>3</Order>
              <Extend>true</Extend>
              <Type>Primary</Type>
            </CreatePartition>
          </CreatePartitions>
          <ModifyPartitions>
            <ModifyPartition wcm:action="add">
              <Order>1</Order>
              <PartitionID>1</PartitionID>
              <Format>FAT32</Format>
              <Label>System</Label>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>2</Order>
              <PartitionID>2</PartitionID>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>3</Order>
              <PartitionID>3</PartitionID>
              <Format>NTFS</Format>
              <Label>Windows</Label>
              <Letter>C</Letter>
            </ModifyPartition>
          </ModifyPartitions>
          {% else %}
          <!-- MBR layout for BIOS -->
          <CreatePartitions>
            <!-- System Reserved -->
            <CreatePartition wcm:action="add">
              <Order>1</Order>
              <Size>500</Size>
              <Type>Primary</Type>
              <Active>true</Active>
            </CreatePartition>
            <!-- Windows OS -->
            <CreatePartition wcm:action="add">
              <Order>2</Order>
              <Extend>true</Extend>
              <Type>Primary</Type>
            </CreatePartition>
          </CreatePartitions>
          <ModifyPartitions>
            <ModifyPartition wcm:action="add">
              <Order>1</Order>
              <PartitionID>1</PartitionID>
              <Format>NTFS</Format>
              <Label>System Reserved</Label>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>2</Order>
              <PartitionID>2</PartitionID>
              <Format>NTFS</Format>
              <Label>Windows</Label>
              <Letter>C</Letter>
            </ModifyPartition>
          </ModifyPartitions>
          {% endif %}
        </Disk>
      </DiskConfiguration>

      <ImageInstall>
        <OSImage>
          <InstallTo>
            <DiskID>{{ disk_id }}</DiskID>
            {% if is_uefi %}
            <PartitionID>3</PartitionID>
            {% else %}
            <PartitionID>2</PartitionID>
            {% endif %}
          </InstallTo>
          {% if image_name %}
          <InstallFrom>
            <MetaData wcm:action="add">
              <Key>/IMAGE/NAME</Key>
              <Value>{{ image_name }}</Value>
            </MetaData>
          </InstallFrom>
          {% endif %}
        </OSImage>
      </ImageInstall>
    </component>

    {% if driver_paths %}
    <!-- Driver injection for WinPE (VirtIO, storage, NIC) -->
    <component name="Microsoft-Windows-PnpCustomizationsWinPE"
               processorArchitecture="{{ profile.arch | default('amd64') }}"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">
      <DriverPaths>
        {% for dp in driver_paths %}
        <PathAndCredentials wcm:action="add" wcm:keyValue="{{ loop.index }}">
          <Path>{{ dp }}</Path>
        </PathAndCredentials>
        {% endfor %}
      </DriverPaths>
    </component>
    {% endif %}
  </settings>

  <!-- ======================== -->
  <!-- Pass 4: specialize        -->
  <!-- ======================== -->
  <settings pass="specialize">

    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="{{ profile.arch | default('amd64') }}"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">
      <ComputerName>{{ hostname }}</ComputerName>
      <TimeZone>{{ timezone }}</TimeZone>
      {% if organization %}
      <RegisteredOrganization>{{ organization }}</RegisteredOrganization>
      {% endif %}
      <RegisteredOwner>{{ owner }}</RegisteredOwner>
    </component>

    {% if not use_dhcp %}
    <component name="Microsoft-Windows-TCPIP"
               processorArchitecture="{{ profile.arch | default('amd64') }}"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">
      <Interfaces>
        <Interface wcm:action="add">
          <Identifier>Ethernet</Identifier>
          <Ipv4Settings>
            <DhcpEnabled>false</DhcpEnabled>
          </Ipv4Settings>
          <UnicastIpAddresses>
            <IpAddress wcm:action="add" wcm:keyValue="1">{{ ipv4 }}/{{ netmask }}</IpAddress>
          </UnicastIpAddresses>
          <Routes>
            <Route wcm:action="add">
              <Identifier>0</Identifier>
              <NextHopAddress>{{ gateway }}</NextHopAddress>
              <Prefix>0.0.0.0/0</Prefix>
              <Metric>10</Metric>
            </Route>
          </Routes>
        </Interface>
      </Interfaces>
    </component>

    <component name="Microsoft-Windows-DNS-Client"
               processorArchitecture="{{ profile.arch | default('amd64') }}"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">
      <Interfaces>
        <Interface wcm:action="add">
          <Identifier>Ethernet</Identifier>
          <DNSServerSearchOrder>
            {% for ns in nameservers %}
            <IpAddress wcm:action="add" wcm:keyValue="{{ loop.index }}">{{ ns }}</IpAddress>
            {% endfor %}
          </DNSServerSearchOrder>
        </Interface>
      </Interfaces>
    </component>
    {% endif %}

    {% if profile.extra.get('join_domain') %}
    <component name="Microsoft-Windows-UnattendedJoin"
               processorArchitecture="{{ profile.arch | default('amd64') }}"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">
      <Identification>
        <JoinDomain>{{ profile.extra['join_domain'] }}</JoinDomain>
        {% if profile.extra.get('domain_ou') %}
        <MachineObjectOU>{{ profile.extra['domain_ou'] }}</MachineObjectOU>
        {% endif %}
        <Credentials>
          <Domain>{{ profile.extra['join_domain'] }}</Domain>
          <Username>{{ profile.extra.get('domain_user', 'Administrator') }}</Username>
          <Password>{{ profile.extra.get('domain_password', '') }}</Password>
        </Credentials>
      </Identification>
    </component>
    {% endif %}
  </settings>

  <!-- ======================== -->
  <!-- Pass 7: oobeSystem        -->
  <!-- ======================== -->
  <settings pass="oobeSystem">

    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="{{ profile.arch | default('amd64') }}"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">

      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <NetworkLocation>Work</NetworkLocation>
        <ProtectYourPC>1</ProtectYourPC>
        <SkipMachineOOBE>true</SkipMachineOOBE>
        <SkipUserOOBE>true</SkipUserOOBE>
      </OOBE>

      {% if auto_logon %}
      <AutoLogon>
        <Enabled>true</Enabled>
        <LogonCount>{{ auto_logon_count }}</LogonCount>
        <Username>Administrator</Username>
        <Password>
          <Value>{{ admin_password }}</Value>
          <PlainText>true</PlainText>
        </Password>
      </AutoLogon>
      {% endif %}

      <UserAccounts>
        <AdministratorPassword>
          <Value>{{ admin_password }}</Value>
          <PlainText>true</PlainText>
        </AdministratorPassword>
      </UserAccounts>

      {% if post_scripts or setup_complete %}
      <FirstLogonCommands>
        {% for script in post_scripts %}
        <SynchronousCommand wcm:action="add">
          <Order>{{ loop.index }}</Order>
          <CommandLine>{{ script }}</CommandLine>
          <Description>Post-install script {{ loop.index }}</Description>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>
        {% endfor %}
        {% if setup_complete %}
        <SynchronousCommand wcm:action="add">
          <Order>{{ (post_scripts | length) + 1 }}</Order>
          <CommandLine>cmd /c {{ setup_complete }}</CommandLine>
          <Description>SetupComplete script</Description>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>
        {% endif %}
      </FirstLogonCommands>
      {% endif %}

    </component>

    <component name="Microsoft-Windows-International-Core"
               processorArchitecture="{{ profile.arch | default('amd64') }}"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">
      <InputLocale>{{ input_locale }}</InputLocale>
      <SystemLocale>{{ locale }}</SystemLocale>
      <UILanguage>{{ locale }}</UILanguage>
      <UserLocale>{{ locale }}</UserLocale>
    </component>

  </settings>

</unattend>
